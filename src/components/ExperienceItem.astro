---
import type { Experience } from "@/data/experience";

interface Props {
  item: Experience;
}

const { item } = Astro.props;
---

<div class="group flex flex-col gap-1 py-6 first:pt-0 sm:flex-row sm:gap-8">
  <p class="shrink-0 font-mono text-sm text-[var(--text-muted)] sm:w-32">
    {item.year}
  </p>
  <div class="flex-1">
    <div
      class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between"
    >
      <h3 class="text-lg font-semibold">{item.role}</h3>
      <p class="font-mono text-sm text-[var(--text-muted)]">{item.company}</p>
    </div>
    {
      item.bullets && item.bullets.length > 0 && (
        <ul class="mt-2 space-y-1">
          {item.bullets.map(bullet => (
            <li class="flex items-start gap-2 text-sm text-[var(--text-muted)]">
              <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-accent" />
              {bullet}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</div>
