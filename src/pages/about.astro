---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import { SITE } from "@/config";
import { PROFILE } from "@/data/profile";
import { EXPERIENCE } from "@/data/experience";
import ContactForm from "@/components/ContactForm.astro";
import GitHubActivity from "@/components/GitHubActivity.astro";
import ExperienceItem from "@/components/ExperienceItem.astro";

const TOOLS: { name: string; category: string }[] = [
  { name: "Astro", category: "Frontend" },
  { name: "React", category: "Frontend" },
  { name: "Tailwind CSS", category: "Frontend" },
  { name: "TypeScript", category: "Frontend" },
  { name: "Node.js", category: "Backend" },
  { name: "Supabase", category: "Backend" },
  { name: "PostgreSQL", category: "Backend" },
  { name: "Vercel", category: "Deployment" },
  { name: "GitHub", category: "Workflow" },
  { name: "Cursor", category: "Workflow" },
  { name: "Claude", category: "AI" },
  { name: "ChatGPT", category: "AI" },
];

const toolsByCategory = TOOLS.reduce<Record<string, string[]>>((acc, tool) => {
  if (!acc[tool.category]) acc[tool.category] = [];
  acc[tool.category].push(tool.name);
  return acc;
}, {});
---

<Layout
  title={`About | ${SITE.title}`}
  description={PROFILE.bio}
  ogImage="/images/profile-about.jpg"
>
  <Header />
  <main id="main-content" class="app-layout pb-16">
    <BackButton />

    <!-- ── Hero ── -->
    <section id="about" class="border-b border-border pt-4 pb-12">
      <p
        class="font-mono text-xs tracking-widest text-[var(--text-muted)] uppercase"
      >
        About
      </p>
      <h1 class="mt-2 text-3xl font-semibold sm:text-4xl">
        Builder, learner, and systems-minded experimenter.
      </h1>

      <div class="mt-8 flex flex-col items-start gap-8 md:flex-row">
        <div class="w-28 shrink-0 md:w-44" style="aspect-ratio:3/4">
          <img
            src="/images/profile-about.jpg"
            alt={PROFILE.name}
            width="176"
            height="235"
            class="h-full w-full rounded-lg object-cover object-top"
          />
        </div>

        <div class="min-w-0 flex-1 space-y-4 text-sm leading-relaxed">
          <p>{PROFILE.bio}</p>
          <p class="text-[var(--text-muted)]">
            I like building hobby projects, testing ideas, and writing down the
            parts that were actually worth keeping. Some of the work stays
            small. Some turns into a real tool. Both are fine.
          </p>
          <p class="text-[var(--text-muted)]">
            I split my time between learning, building, and simplifying things
            that started too complicated.
          </p>
          <p class="text-[var(--text-muted)]">
            The homepage is the short version. This page fills in the rest.
          </p>
        </div>
      </div>
    </section>

    <!-- ── Stack ── -->
    <section id="tools" class="border-b border-border py-12">
      <p
        class="font-mono text-xs tracking-widest text-[var(--text-muted)] uppercase"
      >
        Stack
      </p>
      <h2 class="mt-2 text-2xl font-semibold">Tools I use</h2>
      <p class="mt-2 text-sm text-[var(--text-muted)]">
        The stack I reach for when building something real.
      </p>

      <div class="mt-6 flex flex-wrap gap-x-8 gap-y-5">
        {
          Object.entries(toolsByCategory).map(([category, tools]) => (
            <div>
              <p class="mb-2 font-mono text-xs tracking-wider text-[var(--text-muted)] uppercase">
                {category}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {tools.map(tool => (
                  <span class="rounded-full border border-border px-3 py-1 text-xs text-[var(--text-muted)]">
                    {tool}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ── GitHub Activity ── -->
    <GitHubActivity />

    <!-- ── Experience ── -->
    <section id="experience" class="border-b border-border py-12">
      <p
        class="font-mono text-xs tracking-widest text-[var(--text-muted)] uppercase"
      >
        Background
      </p>
      <h2 class="mt-2 text-2xl font-semibold">Experience</h2>

      <div class="mt-8 space-y-2">
        {EXPERIENCE.map(item => <ExperienceItem item={item} />)}
      </div>
    </section>

    <!-- ── Contact ── -->
    <section id="contact" class="py-12">
      <p
        class="font-mono text-xs tracking-widest text-[var(--text-muted)] uppercase"
      >
        Contact
      </p>
      <h2 class="mt-2 text-2xl font-semibold">Stay connected</h2>

      <div class="mt-6 rounded-lg border border-border bg-[var(--panel)] p-6">
        <p class="text-sm text-[var(--text-muted)]">
          If you'd like to connect or have questions about my work, feel free to
          reach out.
        </p>
        <ContactForm />
        <div class="mt-4 flex flex-wrap gap-4 text-sm text-[var(--text-muted)]">
          <a
            href={PROFILE.github}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent">GitHub ↗</a
          >
          <a
            href={PROFILE.twitter}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent">X ↗</a
          >
          <a
            href={PROFILE.kaggle}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent">Kaggle ↗</a
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
